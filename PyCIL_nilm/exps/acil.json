{
    "model_name": "acil",
    "prefix": "ACIL",
    "memory_size": 0,

    "dataset": "case_1",
    "seed": [4],
    "shuffle": true,
    "device": ["0"],

    "convnet_type": "resnet20",
    "init_cls": 10,
    "increment": 3 ,

    "num_workers": 0,
    "init_batch_size": 128,
    "IL_batch_size": 4096,
    "inplace_repeat": 1,

    "configurations": {
        "plaid": {
            "buffer_size": 220,
            "gamma": 0.1,
            "init_weight_decay": 5e-4,
            "scheduler": {
                "type": "MultiStep",
                "init_lr": 0.1,
                "init_epochs": 100,
                "warmup": 0,
                "milestones": [30, 70],
                "decay": 0.1
            }
        },
        "whited": {
            "buffer_size": 220,
            "gamma": 0.1,
            "init_weight_decay": 5e-4,
            "scheduler": {
                "type": "MultiStep",
                "init_lr": 0.1,
                "init_epochs": 100,
                "warmup": 0,
                "milestones": [30, 70],
                "decay": 0.1
            }
        },
        "cooll": {
            "buffer_size": 220,
            "gamma": 0.1,
            "init_weight_decay": 5e-4,
            "scheduler": {
                "type": "MultiStep",
                "init_lr": 0.1,
                "init_epochs": 100,
                "warmup": 0,
                "milestones": [30, 70],
                "decay": 0.1
            }
        },
        "case_2": {
            "buffer_size": 220,
            "gamma": 0.1,
            "init_weight_decay": 5e-4,
            "scheduler": {
                "type": "MultiStep",
                "init_lr": 0.1,
                "init_epochs": 100,
                "warmup": 0,
                "milestones": [30, 70],
                "decay": 0.1
            }
        },


        "cifar100": {
            "buffer_size": 8192,
            "gamma": 0.1,
            "init_weight_decay": 5e-4,
            "scheduler": {
                "type": "MultiStep",
                "init_lr": 0.1,
                "init_epochs": 160,
                "warmup": 0,
                "milestones": [120, 140],
                "decay": 0.1
            }
        },
        "imagenet1000": {
            "buffer_size": 16384,
            "gamma": 0.1,
            "init_weight_decay": 5e-5,
            "scheduler": {
                "type": "MultiStep",
                "init_lr": 0.1,
                "init_epochs": 90,
                "warmup": 0,
                "milestones": [30, 60],
                "decay": 0.1
            }
        }
    }
}
